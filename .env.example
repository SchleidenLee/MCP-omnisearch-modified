# MCP Omnisearch Environment Variables
# Copy this file to .env and fill in your actual API keys

# Search Providers
TAVILY_API_KEY=
BRAVE_API_KEY=
KAGI_API_KEY=
EXA_API_KEY=

# AI Response Providers
LINKUP_API_KEY=

# Processing Providers
FIRECRAWL_API_KEY=

# GitHub
GITHUB_API_KEY=

# Proxy (optional)
HTTPS_PROXY=http://127.0.0.1:7897
HTTP_PROXY=http://127.0.0.1:7897

# Large Result Mode (optional): file or inline
OMNISEARCH_LARGE_RESULT_MODE=file
